{
    "name": "tracking-bap",
    "version": 2,
    "env": {
        "VERCEL": "1",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "VIEW_COMPILED_PATH": "/tmp"
    },
    "builds": [
        {
            "src": "api/vercel.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "api/test.php",
            "use": "vercel-php@0.9.0"
        },

        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/vercel.php"
        }
    ]
}
